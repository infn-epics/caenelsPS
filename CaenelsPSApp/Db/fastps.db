
record (ai, "$(P)$(R)rangeI")
{
    field(DESC, "Range current")

    field(PINI,  "YES")
    field(VAL,$(RANGEI=30))
    field(FLNK, "$(P)$(R)CalcFanoutI")
}

record (ai, "$(P)$(R)rangeV")
{
    field(DESC, "Range voltage")
    field(PINI,  "YES")
    field(VAL,$(RANGEV=20))
    field(FLNK, "$(P)$(R)CalcFanoutV")
}
record(fanout, "$(P)$(R)CalcFanoutI")
{
    field(LNK1, "$(P)$(R)LimitMinI")
    field(LNK2, "$(P)$(R)LimitMaxI")
    field(LNK3, "$(P)$(R)LimitMaxOutputCurrent_")
    field(LNK4, "$(P)$(R)LimitMinOutputCurrent_")
    field(LNK5, "$(P)$(R)SlewRateICalc_")
}
record(fanout, "$(P)$(R)CalcFanoutV")
{
    field(LNK1, "$(P)$(R)LimitMinV")
    field(LNK2, "$(P)$(R)LimitMaxV")
    field(LNK3, "$(P)$(R)LimitMaxOutputVoltage_")
    field(LNK4, "$(P)$(R)LimitMinOutputVoltage_")
    field(LNK5, "$(P)$(R)SlewRateVCalc_")
}
record (calcout, "$(P)$(R)LimitMinI")
{
    field(DESC, "Low limit for Current")
    field(INPA, "$(P)$(R)rangeI")
    field(CALC,  "-ABS(A)")
    field(OUT,  "$(P)$(R)Current.LOPR")
}
record (calcout, "$(P)$(R)LimitMaxI")
{
    field(DESC, "Hi limit for Current")
    field(INPA, "$(P)$(R)rangeI")
    field(CALC,  "ABS(A)")
    field(OUT,  "$(P)$(R)Current.HOPR")
}

record (calcout, "$(P)$(R)LimitMaxOutputCurrent_")
{
    field(DESC, "High limit for OutputCurrent")
    field(INPA, "$(P)$(R)rangeI")
    field(CALC,  "ABS(A)")
    field(OUT,  "$(P)$(R)OutputCurrent.HOPR")
}

record (calcout, "$(P)$(R)LimitMinOutputCurrent_")
{
    field(DESC, "High limit for OutputCurrent")
    field(INPA, "$(P)$(R)rangeI")
    field(CALC,  "-ABS(A)")
    field(OUT,  "$(P)$(R)OutputCurrent.LOPR")
}

record (calcout, "$(P)$(R)LimitMinV")
{
    field(DESC, "Low limit for Voltage")
    field(INPA, "$(P)$(R)rangeV")
    field(CALC,  "-ABS(A)")
    field(OUT,  "$(P)$(R)Voltage.LOPR")
}
record (calcout, "$(P)$(R)LimitMaxV")
{
    field(DESC, "Hi limit for Voltage")
    field(INPA, "$(P)$(R)rangeV")
    field(CALC,  "ABS(A)")
    field(OUT,  "$(P)$(R)Voltage.HOPR")
}

record (calcout, "$(P)$(R)LimitMaxOutputVoltage_")
{
    field(DESC, "High limit for OutputVoltage")
    field(INPA, "$(P)$(R)rangeV")
    field(CALC,  "ABS(A)")
    field(OUT,  "$(P)$(R)OutputVoltage.HOPR")
}

record (calcout, "$(P)$(R)LimitMinOutputVoltage_")
{
    field(DESC, "High limit for OutputVoltage")
    field(INPA, "$(P)$(R)rangeV")
    field(CALC,  "-ABS(A)")
    field(OUT,  "$(P)$(R)OutputVoltage.LOPR")
}



################################################################################
# Slew rate set/readback
################################################################################

record(calcout, "$(P)$(R)SlewRateICalc_")
{
    field(DESC, "Compute default current slew rate")
    field(INPA, "$(P)$(R)rangeI")
    field(B, "$(RAMPI=0)")
    field(CALC, "B>0?B:A*0.1")
    field(OUT,  "$(P)$(R)SlewRateI PP")
}

record(ao, "$(P)$(R)SlewRateI")
{
    field(DESC, "Current slew rate")
    field(DTYP, "stream")
    field(EGU,  "A/s")
    field(OUT,  "@fastps.proto setSlewRateI $(PORT)")
    field(PREC, "3")
    field(PINI, "YES")
}

record(ai, "$(P)$(R)SlewRateIRB")
{
    field(DESC, "Current slew rate readback")
    field(DTYP, "stream")
    field(EGU,  "A/s")
    field(INP,  "@fastps.proto getSlewRateI $(PORT)")
    field(FLNK, "$(P)$(R)SlewRateVRB")
    field(PREC, "3")
}

record(calcout, "$(P)$(R)SlewRateVCalc_")
{
    field(DESC, "Compute default voltage slew rate")
    field(INPA, "$(P)$(R)rangeV")
    field(B, "$(RAMPV=0)")
    field(CALC, "B>0?B:A*0.1")
    field(OUT,  "$(P)$(R)SlewRateV PP")
}

record(ao, "$(P)$(R)SlewRateV")
{
    field(DESC, "Voltage slew rate")
    field(DTYP, "stream")
    field(EGU,  "V/s")
    field(OUT,  "@fastps.proto setSlewRateV $(PORT)")
    field(PREC, "3")
    field(PINI, "YES")
}

record(ai, "$(P)$(R)SlewRateVRB")
{
    field(DESC, "Voltage slew rate readback")
    field(DTYP, "stream")
    field(EGU,  "V/s")
    field(INP,  "@fastps.proto getSlewRateV $(PORT)")
    field(FLNK, "$(P)$(R)StatusMSB")
    field(PREC, "3")
}

################################################################################
# Control
################################################################################

record(bo, "$(P)$(R)RegulationMode")
{
    field(DESC, "Selects between voltage/current reg")
    field(DTYP, "stream")
    field(OUT,  "@fastps.proto setRegulationMode $(PORT)")
    field(PINI, "YES")
    field(VAL, "I")
    field(ZNAM, "V")
    field(ONAM, "I")
}

record(ao, "$(P)$(R)Voltage")
{
    field(DESC, "Voltage control")
    field(DTYP, "stream")
    field(EGU,  "V")
    field(OUT,  "@fastps.proto setVoltageRamp $(PORT)")
    field(PREC, "5")
}

record(ao, "$(P)$(R)Current")
{
    field(DESC, "Current control")
    field(DTYP, "stream")
    field(EGU,  "A")
    field(OUT,  "@fastps.proto setCurrentRamp $(PORT)")
    field(PREC, "5")
}

record(bo, "$(P)$(R)UpdateMode")
{
    field(DESC, "Update mode (Normal/Analog)")
    field(DTYP, "stream")
    field(OUT,  "@fastps.proto setUpdateMode $(PORT)")
    field(PINI, "YES")
    field(ZNAM, "Normal")
    field(ONAM, "Analog")
}

record(bo, "$(P)$(R)FloatMode")
{
    field(DESC, "Floating output mode")
    field(DTYP, "stream")
    field(OUT,  "@fastps.proto setFloatMode $(PORT)")
    field(PINI, "YES")
    field(ZNAM, "Grounded")
    field(ONAM, "Floating")
}

record(bo, "$(P)$(R)StatusReset")
{
    field(DESC, "Reset status register/clear faults")
    field(DTYP, "stream")
    field(OUT,  "@fastps.proto resetStatus $(PORT)")
}

record(bo, "$(P)$(R)SaveParams")
{
    field(DESC, "Save config to non-volatile memory")
    field(DTYP, "stream")
    field(OUT,  "@fastps.proto saveParams $(PORT)")
    field(ZNAM, "Idle")
    field(ONAM, "Save")
}

record(bo, "$(P)$(R)HWReset")
{
    field(DESC, "Hardware reset")
    field(DTYP, "stream")
    field(OUT,  "@fastps.proto hwReset $(PORT)")
    field(ZNAM, "Idle")
    field(ONAM, "Reset")
}

################################################################################
record(bi, "$(P)$(R)ReadbackPoll_")
{
    field(DESC, "Head of readback chain")
    field(FLNK, "$(P)$(R)OutputVoltage")
    field(PINI, "YES")
    field(INP,  "0")
    field(SCAN, "1 second")
}

record(ai, "$(P)$(R)OutputVoltage")
{
    field(DESC, "Output voltage")
    field(DTYP, "stream")
    field(EGU,  "V")
    field(FLNK, "$(P)$(R)OutputCurrent")
    field(INP,  "@fastps.proto getOutputVoltage $(PORT)")
    field(PREC, "5")
}

record(ai, "$(P)$(R)OutputCurrent")
{
    field(DESC, "Output current")
    field(DTYP, "stream")
    field(EGU,  "A")
    field(FLNK, "$(P)$(R)GroundCurrent")
    field(INP,  "@fastps.proto getOutputCurrent $(PORT)")
    field(PREC, "5")
}

record(ai, "$(P)$(R)GroundCurrent")
{
    field(DESC, "Ground current")
    field(DTYP, "stream")
    field(EGU,  "A")
    field(FLNK, "$(P)$(R)DCLinkVoltage")
    field(INP,  "@fastps.proto getGroundCurrent $(PORT)")
    field(PREC, "3")
}

record(ai, "$(P)$(R)DCLinkVoltage")
{
    field(DESC, "DC Link voltage")
    field(DTYP, "stream")
    field(EGU,  "V")
    field(FLNK, "$(P)$(R)HeatsinkTemp")
    field(INP,  "@fastps.proto getDCLinkVoltage $(PORT)")
    field(PREC, "2")
}

record(ai, "$(P)$(R)HeatsinkTemp")
{
    field(DESC, "Heatsink temperature")
    field(DTYP, "stream")
    field(EGU,  "deg C")
    field(FLNK, "$(P)$(R)OutputPower")
    field(INP,  "@fastps.proto getTemperature $(PORT)")
    field(PREC, "2")
}

record(ai, "$(P)$(R)OutputPower")
{
    field(DESC, "Output power")
    field(DTYP, "stream")
    field(EGU,  "W")
    field(FLNK, "$(P)$(R)SlewRateIRB")
    field(INP,  "@fastps.proto getOutputPower $(PORT)")
    field(PREC, "3")
}


record(mbbiDirect, "$(P)$(R)StatusMSB")
{
    field(DESC, "Status MSB")
    field(DTYP, "stream")
    field(FLNK, "$(P)$(R)StatusLSB")
    field(INP,  "@fastps.proto getStatusMSB $(PORT)")
}


record(mbbiDirect, "$(P)$(R)StatusLSB")
{
    field(DESC, "Status LSB")
    field(DTYP, "stream")
#    field(FLNK, "$(P)$(R)Limits")
    field(INP,  "@fastps.proto getStatusLSB $(PORT)")
}

